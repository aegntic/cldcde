# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token
CLOUDFLARE_EMAIL=your-email@example.com

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Optional: AI Services
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key

# Optional: GitHub Integration
GITHUB_TOKEN=your-github-token
GITHUB_USERNAME=your-username

# Optional: Monitoring
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_ENDPOINT=http://localhost:9090

# Agent Configuration
HILLM_STRICTNESS_LEVEL=MAXIMUM  # STANDARD, HIGH, MAXIMUM
AGENT_LEARNING_ENABLED=true
AGENT_MEMORY_BACKEND=graphiti  # graphiti, redis, postgres

# Deployment Settings
DEPLOYMENT_ENVIRONMENT=development  # development, staging, production
DEPLOYMENT_SAFETY_CHECKS=true
DEPLOYMENT_AUTO_ROLLBACK=true

# Security
ENCRYPTION_KEY=generate-a-secure-key-here
JWT_SECRET=another-secure-key-here
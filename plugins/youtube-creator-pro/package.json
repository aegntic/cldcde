{
  "name": "@cldcde/youtube-creator-pro",
  "version": "1.0.0",
  "description": "Advanced YouTube Creator Plugin with AI-Powered Workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "bun x eslint src/**/*.ts",
    "format": "bun x prettier --write src/**/*.ts"
  },
  "keywords": [
    "youtube",
    "ai",
    "analytics",
    "automation",
    "optimization",
    "creator-pro",
    "cldcde",
    "creator-tools",
    "aegntic"
  ],
  "author": "AEGNTIC AI Ecosystems for CLDCDE",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aegntic/cldcde-plugins.git",
    "directory": "plugins/youtube-creator-pro"
  },
  "dependencies": {
    "@claude-code/tool-access": "^1.0.0",
    "@cldcde/youtube-creator": "^1.0.0",
    "anthropic": "^0.25.0",
    "openai": "^4.20.0",
    "googleapis": "^128.0.0",
    "node-fetch": "^3.3.2",
    "form-data": "^4.0.0",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/form-data": "^4.0.0",
    "typescript": "^5.2.2",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3"
  },
  "peerDependencies": {
    "bun": ">=1.0.0",
    "@cldcde/youtube-creator": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "cldcde": {
    "type": "plugin",
    "tier": "pro",
    "category": "content-creation",
    "capabilities": [
      "ai-content-generation",
      "automation",
      "data-analysis"
    ],
    "compatibility": {
      "cldcde": ">=1.0.0"
    },
    "permissions": [
      "ai:model-access"
    ],
    "branding": {
      "logo": "https://cldcde.cc/assets/logo.png",
      "brandColor": "#00ff41",
      "terminalStyle": true
    }
  },
  "homepage": "https://cldcde.cc",
  "bugs": {
    "url": "https://github.com/aegntic/cldcde/issues"
  }
}

{
  "name": "@cldcde/ai-memory-server",
  "version": "1.0.0",
  "description": "MCP server for accessing ChatGPT, Grok, and Gemini conversations and memory",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "build": "npm run start"
  },
  "keywords": [
    "mcp",
    "claude",
    "chatgpt",
    "grok",
    "gemini",
    "ai",
    "memory",
    "cldcde",
    "creator-tools",
    "aegntic"
  ],
  "author": "AEGNTIC AI Ecosystems for CLDCDE",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "node-fetch": "^3.3.2",
    "cheerio": "^1.0.0-rc.12",
    "puppeteer": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "homepage": "https://cldcde.cc",
  "repository": {
    "type": "git",
    "url": "https://github.com/aegntic/cldcde.git",
    "directory": "mcp-servers/ai-memory-server"
  },
  "bugs": {
    "url": "https://github.com/aegntic/cldcde/issues"
  },
  "cldcde": {
    "type": "mcp-server",
    "tier": "elite",
    "category": "ai-integration",
    "capabilities": [
      "ai-content-generation"
    ],
    "compatibility": {
      "cldcde": ">=1.0.0"
    },
    "permissions": [
      "ai:model-access"
    ],
    "branding": {
      "logo": "https://cldcde.cc/assets/logo.png",
      "brandColor": "#00ff41",
      "terminalStyle": true
    }
  }
}
